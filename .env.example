# cp .env.example .env  — then fill in. Keep this file blank; it's committed.
# The backend reads .env once at startup, so restart it after any change.

# Enable "Places API (New)" + "Street View Static API", with billing on.
# https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=

# Covers both the vision and image models. https://aistudio.google.com/apikey
# Free tier is ~5 req/min, so runs are slow and image generation may be blocked.
GEMINI_API_KEY=

# https://supabase.com — create a project, run supabase/migrations/ in order,
# then copy these from Settings -> API.
# SERVICE_ROLE bypasses row-level security: backend only, never send to a browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_BUCKET=storefront-visuals


# --- Optional. Defaults in backend/app/config.py. --------------------------- #

# Blank uses the confirmed-working defaults.
GEMINI_VISION_MODEL=
GEMINI_IMAGE_MODEL=

# Seconds between Gemini calls. 13 avoids free-tier rate limits; 0 once billing
# is on.
GEMINI_MIN_INTERVAL_S=

# How much a run does. The UI can change these per run, up to the hard caps.
MAX_VENUES=8
TARGET_ACCEPTED=3
MAX_VENUES_HARD_CAP=12
TARGET_ACCEPTED_HARD_CAP=6

DRY_RUN=false
CACHE_ENABLED=true
MAX_RUNS_PER_HOUR=3

# Your deployed frontend, e.g. https://your-app.vercel.app
CORS_EXTRA_ORIGINS=

# Frontend config goes in frontend/.env.local, and only if the backend isn't on
# the default port: VITE_API_BASE_URL=http://localhost:8001
